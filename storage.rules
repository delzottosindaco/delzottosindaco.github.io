rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read access to everyone
      allow read: if true;
      
      // Allow write access to any authenticated user during development
      // This helps if the specific admin email check is failing
      allow write: if request.auth != null;
    }
  }
}
