{
  "entities": {
    "Candidate": {
      "title": "Candidate",
      "description": "A candidate in the election campaign",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the candidate" },
        "img": { "type": "string", "description": "URL of the candidate's profile image" },
        "cvUrl": { "type": "string", "description": "URL of the candidate's CV (PDF)" },
        "position": { "type": "number", "description": "Order of appearance (1-36)" },
        "uid": { "type": "string", "description": "Creator UID" },
        "bio": { "type": "string", "description": "Short biography" },
        "policies": { "type": "array", "items": { "type": "string" }, "description": "Key policy stances" }
      },
      "required": ["name", "position"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "url": { "type": "string", "description": "URL of the image or resource" }
      }
    },
    "Contact": {
      "title": "Contact",
      "description": "A message from a citizen",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender's name" },
        "email": { "type": "string", "format": "email", "description": "Sender's email" },
        "type": { "type": "string", "enum": ["proposta", "domanda", "segnalazione", "altro"], "description": "Type of message" },
        "message": { "type": "string", "description": "Message content" },
        "privacy": { "type": "boolean", "description": "Privacy consent" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission time" },
        "status": { "type": "string", "enum": ["new", "read", "archived"], "description": "Message status" }
      },
      "required": ["name", "email", "message", "privacy"]
    }
  },
  "firestore": {
    "/candidates/{candidateId}": {
      "schema": "Candidate",
      "description": "Collection of election candidates"
    },
    "/settings/{settingId}": {
      "schema": "Setting",
      "description": "Global site settings like hero and project images"
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Collection of citizen messages and proposals"
    }
  }
}
