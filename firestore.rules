rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: candidates
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - img: string (optional)
    //   - cvUrl: string (optional)
    //   - position: number (required)
    //   - uid: string (optional)
    //
    // Collection: contacts
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - email: string (required)
    //   - type: string (required)
    //   - message: string (required)
    //   - privacy: bool (required)
    //   - createdAt: string (required)
    //   - status: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "daniela@coletti.it" && request.auth.token.email_verified == true);
    }

    function isValidCandidate(data) {
      return data.keys().hasAll(['name', 'position']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.position is number &&
             (!('img' in data) || (data.img is string && data.img.size() < 1000)) &&
             (!('cvUrl' in data) || (data.cvUrl is string && data.cvUrl.size() < 1000)) &&
             (!('uid' in data) || (data.uid is string));
    }

    match /contacts/{contactId} {
      // Anyone can submit a message
      allow create: if true; 
      // Only admins can read or manage messages
      allow read, update, delete: if isAdmin();
    }

    match /candidates/{candidateId} {
      // Publicly readable for the website
      allow read: if true;
      
      // Only admins can modify the team
      allow create: if isAdmin() && isValidCandidate(request.resource.data);
      allow update: if isAdmin() && isValidCandidate(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
